NODE_ENV=production
PORT=3000

POSTGRES_DB=majormodels
POSTGRES_USER=majormodels
POSTGRES_PASSWORD=change_me_strong_password
DB_VOLUME_NAME=majormodels_postgres_data_prod

# Internal network host is `db` from docker-compose.prod.yml
DATABASE_URL=postgresql://majormodels:change_me_strong_password@db:5432/majormodels?schema=public

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_ADMIN_CHAT_ID=replace_me
# Optional: override backend base URL for Telegram bot API calls.
# Default fallback: http://127.0.0.1:${PORT}/api/v1
TELEGRAM_BACKEND_BASE_URL=http://127.0.0.1:3000/api/v1

# Product media files are mounted in docker-compose.prod.yml from /opt/majormodels-media
MEDIA_ROOT=/app/media

# Optional migration retry tuning
DB_MIGRATION_MAX_ATTEMPTS=20
DB_MIGRATION_RETRY_SECONDS=3
